# Copy this content into Dokploy → Admin App → Advanced → Mounts → File Mount
# File path: /app/.env

APP_MODE=admin
ADMIN_PANEL_PASSWORD=change-me
ADMIN_PANEL_HOST=0.0.0.0
ADMIN_PANEL_PORT=8080

BOT_TOKEN=your_bot_token
MAIN_WALLET=your_solana_wallet
DATA_DIR=/app/data
ENCRYPTION_KEY=your_fernet_key
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
